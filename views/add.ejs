<%- include('partials/headr') %>

<div class="w-full min-h-screen bg-gray-100 flex items-center justify-center p-6">
    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-md">
        <h2 class="text-2xl font-bold mb-6 text-gray-800 text-center">Add New Product</h2>
        
        <form action="/add" method="post" class="space-y-4">
            
            <!-- Title Input -->
            <div>
                <label class="block text-sm font-medium text-gray-700">Product Title</label>
                <input type="text" name="title" required placeholder="Enter product title" 
                    class="mt-1 block w-full px-4 py-2 bg-gray-50 border border-gray-300 rounded-md focus:ring-green-500 focus:border-green-500 outline-none transition">
            </div>

            <!-- Category Radio Buttons -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Category</label>
                <div class="grid grid-cols-2 gap-3">
                    <!-- T-Shirts -->
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                        <input type="radio" name="category" value="T-Shirts" class="w-4 h-4 text-green-600 focus:ring-green-500" checked>
                        <span class="ml-2 text-sm text-gray-700">T-Shirts</span>
                    </label>
                    <!-- Shirts -->
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                        <input type="radio" name="category" value="Shirts" class="w-4 h-4 text-green-600 focus:ring-green-500">
                        <span class="ml-2 text-sm text-gray-700">Shirts</span>
                    </label>
                    <!-- Panjabis -->
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                        <input type="radio" name="category" value="Panjabis" class="w-4 h-4 text-green-600 focus:ring-green-500">
                        <span class="ml-2 text-sm text-gray-700">Panjabis</span>
                    </label>
                    <!-- Trousers -->
                    <label class="flex items-center p-3 border border-gray-200 rounded-lg cursor-pointer hover:bg-gray-50 transition">
                        <input type="radio" name="category" value="Trousers" class="w-4 h-4 text-green-600 focus:ring-green-500">
                        <span class="ml-2 text-sm text-gray-700">Trousers</span>
                    </label>
                </div>
            </div>

            <!-- Price Input -->
            <div>
                <label class="block text-sm font-medium text-gray-700">Price (৳)</label>
                <input type="number" name="price" required placeholder="0.00" step="0.01"
                    class="mt-1 block w-full px-4 py-2 bg-gray-50 border border-gray-300 rounded-md focus:ring-green-500 focus:border-green-500 outline-none transition">
            </div>

            <!-- Image URL Input -->
            <div>
                <label class="block text-sm font-medium text-gray-700">Image URL</label>
                <input type="url" name="imgUrl" required placeholder="https://example.com/image.jpg" 
                    class="mt-1 block w-full px-4 py-2 bg-gray-50 border border-gray-300 rounded-md focus:ring-green-500 focus:border-green-500 outline-none transition">
            </div>

            <!-- Content/Description Input -->
            <div>
                <label class="block text-sm font-medium text-gray-700">Content / Description</label>
                <textarea name="content" rows="4" placeholder="Write something about the product..." 
                    class="mt-1 block w-full px-4 py-2 bg-gray-50 border border-gray-300 rounded-md focus:ring-green-500 focus:border-green-500 outline-none transition"></textarea>
            </div>

            <!-- Submit Button -->
            <button type="submit" 
                class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-md shadow-md transition duration-300 ease-in-out transform hover:-translate-y-1">
                Post Product
            </button>
            
        </form>
    </div>
</div>

<%- include('partials/footer') %>