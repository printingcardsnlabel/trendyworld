<%- include('partials/headr') %>

<div class="w-full min-h-screen bg-gray-50 flex items-center justify-center p-6">
    <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-2xl border border-gray-100">
        <h2 class="text-3xl font-black mb-8 text-gray-900 text-center uppercase tracking-tighter italic">
            Add New <span class="text-red-600">Product</span>
        </h2>
        
        <form action="/add" method="post" class="space-y-6">
            
            <!-- Title Input -->
            <div>
                <label class="block text-xs font-black text-gray-700 uppercase tracking-widest mb-2">Product Title</label>
                <input type="text" name="title" required placeholder="Ex: Premium Cotton Polo Shirt" 
                    class="block w-full px-4 py-3 bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-red-600 outline-none transition-all font-medium">
            </div>

            <!-- Category Section -->
            <div>
                <label class="block text-xs font-black text-gray-700 uppercase tracking-widest mb-4">Select Category</label>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <% const categories = ["Shirt", "T-Shirt", "Drop Shoulder", "Polo T-Shirt", "Jerssy", "Punjabi", "Jeans Pants", "Gabardine Pants"]; %>
                    <% categories.forEach((cat, index) => { %>
                    <label class="relative flex items-center p-3 border-2 border-gray-100 rounded-xl cursor-pointer hover:border-red-500 hover:bg-red-50 transition-all group">
                        <input type="radio" name="category" value="<%= cat %>" class="peer hidden" <%= index === 0 ? 'checked' : '' %>>
                        <span class="text-[10px] font-bold text-gray-600 uppercase group-hover:text-red-600 transition-colors"><%= cat %>'s</span>
                        <div class="absolute inset-0 border-2 border-transparent peer-checked:border-red-600 rounded-xl pointer-events-none"></div>
                    </label>
                    <% }); %>
                </div>
            </div>

            <!-- Pricing Logic Container -->
            <div class="p-5 bg-gray-50 rounded-2xl border border-gray-100 space-y-6">
                <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
                    <!-- Toggles -->
                    <div class="space-y-3">
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="isDiscount" id="discountToggle" value="true" class="sr-only peer">
                            <div class="w-10 h-5 bg-gray-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-red-600"></div>
                            <span class="ms-3 text-[11px] font-black text-gray-700 uppercase">On Discount?</span>
                        </label>

                        <label class="relative inline-flex items-center cursor-pointer block">
                            <input type="checkbox" name="isNewArrival" value="true" class="sr-only peer">
                            <div class="w-10 h-5 bg-gray-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            <span class="ms-3 text-[11px] font-black text-gray-700 uppercase">New Arrival?</span>
                        </label>
                         <label class="relative inline-flex items-center cursor-pointer block">
                            <input type="checkbox" name="isLimited" value="true" class="sr-only peer">
                            <div class="w-10 h-5 bg-gray-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            <span class="ms-3 text-[11px] font-black text-gray-700 uppercase">is Limited?</span>
                        </label>
                    </div>

                    <!-- Regular Price (Always Visible) -->
                    <div class="w-full md:w-1/2">
                        <label class="block text-xs font-black text-gray-700 uppercase mb-2">Regular Price (৳)</label>
                        <input type="number" name="regularPrice" required placeholder="0.00" 
                            class="block w-full px-4 py-2 bg-white border border-gray-200 rounded-lg focus:border-red-600 outline-none">
                    </div>
                </div>

                <!-- Discount Price Field (Hidden by default) -->
                <div id="discountFieldContainer" class="hidden pt-4 border-t border-gray-200 animate-fadeIn">
                    <label class="block text-[10px] font-black text-red-700 uppercase mb-1">Discount Price (৳)</label>
                    <input type="number" name="discountPrice" id="discountPriceInput" placeholder="Enter discounted price" 
                        class="w-full px-4 py-2 text-sm border border-red-200 rounded-lg outline-none focus:border-red-600 bg-red-50">
                </div>
            </div>
<!-- Product Size Input Field -->
<div class="mb-4">
    <label class="block text-sm font-bold text-gray-700 mb-1">Available Sizes (Comma Separated)</label>
    <input type="text" name="sizes" placeholder="e.g. M, L, XL, XXL or 30, 32, 34, 36" 
        class="w-full px-4 py-2.5 border border-gray-200 rounded-lg outline-none focus:border-gray-900 font-medium text-sm transition shadow-sm">
    <p class="text-xs text-gray-400 mt-1">প্রতিটি সাইজ লেখার পর একটি কমা (,) দিন। যেমন: XL, L, M অথবা ৩০, ৩২, ৩৪</p>
</div>
            <!-- Image URL Section -->
            <div class="space-y-4">
                <label class="block text-xs font-black text-gray-700 uppercase tracking-widest italic">Image Gallery</label>
                <input type="url" name="imgUrl" required placeholder="Main Image URL (Required)" 
                    class="block w-full px-4 py-3 bg-white border-2 border-gray-100 rounded-xl focus:border-red-600 outline-none transition-all shadow-sm">
                
                <div class="grid grid-cols-2 gap-3">
                    <input type="url" name="imgUrl2" placeholder="Gallery 1 (Opt)" class="px-4 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-gray-900">
                    <input type="url" name="imgUrl3" placeholder="Gallery 2 (Opt)" class="px-4 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-gray-900">
                    <input type="url" name="imgUrl4" placeholder="Gallery 3 (Opt)" class="px-4 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-gray-900">
                    <input type="url" name="imgUrl5" placeholder="Gallery 4 (Opt)" class="px-4 py-2 text-sm bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-gray-900">
                </div>
            </div>

            <!-- Description -->
            <div>
                <label class="block text-xs font-black text-gray-700 uppercase tracking-widest mb-2">Description</label>
                <textarea name="content" rows="3" placeholder="Describe the fabric, fit and details..." 
                    class="block w-full px-4 py-3 bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-red-600 outline-none transition-all"></textarea>
            </div>

            <button type="submit" 
                class="w-full bg-gray-900 hover:bg-red-600 text-white font-black py-4 rounded-xl shadow-xl transition duration-300 ease-in-out transform hover:-translate-y-1 uppercase tracking-[0.2em] text-sm">
                Upload Product
            </button>
            
        </form>
    </div>
</div>

<script>
    const discountToggle = document.getElementById('discountToggle');
    const discountFieldContainer = document.getElementById('discountFieldContainer');
    const discountPriceInput = document.getElementById('discountPriceInput');

    discountToggle.addEventListener('change', function() {
        if (this.checked) {
            // Show Discount Price Input
            discountFieldContainer.classList.remove('hidden');
            discountPriceInput.required = true;
        } else {
            // Hide Discount Price Input and clear value
            discountFieldContainer.classList.add('hidden');
            discountPriceInput.value = "";
            discountPriceInput.required = false;
        }
    });
</script>

<style>
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out forwards;
    }
</style>

<%- include('partials/footer') %>