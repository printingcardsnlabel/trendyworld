    <script>
      // Swiper Initialize
const swiper = new Swiper('.mainHeroSwiper', {
  // Auto-slide functionality
  autoplay: {
    delay: 3000, // 3 second por por slide change hobe
    disableOnInteraction: false, // User touch/click korle-o autoplay bondho hobe na
  },
  
  // Smooth transition speed
  speed: 800, 

  // Pagination (dots) logic
  pagination: {
    el: '.swiper-pagination',
    clickable: true,
  },

  // Loop enable kora hoyeche jate last slide er por abar prothom-ti ashe
  loop: true,

  // Smooth sliding effect-er jonno (optional)
  effect: 'fade',
  fadeEffect: {
    crossFade: true
  },
});


function gotoCategory(href){
    window.location.href= '/category'+href
}
    </script>

