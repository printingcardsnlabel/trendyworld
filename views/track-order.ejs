<%- include('partials/headr') %>

<section class="py-16 bg-[#fafafa] min-h-screen">
    <div class="container mx-auto px-6 max-w-2xl">
        
        <div class="bg-white border border-gray-100 rounded-3xl p-6 md:p-8 shadow-xl mb-10 space-y-6">
            <div class="text-center space-y-2">
                <h1 class="text-2xl font-black text-gray-950 uppercase tracking-tight italic">
                    Track Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-red-600 to-orange-500">Order</span>
                </h1>
                <p class="text-xs text-gray-400 font-medium">আপনার ৬-সংখ্যার অর্ডার আইডিটি নিচের বক্সে দিয়ে সার্চ করুন।</p>
            </div>

            <form action="/track-order" method="GET" class="flex flex-col sm:flex-row items-center gap-3">
                <div class="relative w-full">
                    <span class="absolute inset-y-0 left-4 flex items-center text-gray-400">
                        <i class="fa-solid fa-hashtag text-xs"></i>
                    </span>
                    <input type="text" name="orderId" value="<%= searchedId %>" required placeholder="Example: 583921" 
                           class="w-full pl-10 pr-4 py-3.5 bg-gray-50 border border-gray-200 focus:border-black rounded-xl text-sm font-bold tracking-widest outline-none transition-all uppercase placeholder:normal-case placeholder:font-normal">
                </div>
                <button type="submit" class="w-full sm:w-auto px-6 py-3.5 bg-black hover:bg-gray-900 text-white font-bold rounded-xl text-xs uppercase tracking-widest shadow-md transition-colors whitespace-nowrap cursor-pointer">
                    <i class="fa-solid fa-magnifying-glass mr-1"></i> Track Now
                </button>
            </form>

            <% if (errorMessage) { %>
                <div class="bg-red-50 border border-red-100 rounded-xl p-4 text-center text-xs font-bold text-red-600 flex items-center justify-center gap-2 animate-shake">
                    <i class="fa-solid fa-circle-exclamation"></i> <%= errorMessage %>
                </div>
            <% } %>
        </div>

        <% if (order) { %>
            <div class="bg-white border border-gray-100 rounded-3xl shadow-xl overflow-hidden">
                <div class="bg-gray-950 px-6 py-4 flex flex-wrap items-center justify-between gap-3 border-b text-white">
                    <div class="space-y-0.5">
                        <span class="text-[9px] text-gray-400 font-bold uppercase tracking-widest block">ORDER REFERENCE CODE</span>
                        <h3 class="text-base font-black tracking-wider font-mono">ID: #<%= order.OrderId %></h3>
                    </div>
                    <div class="text-right">
                        <span class="text-[9px] text-gray-400 font-bold uppercase tracking-widest block">TOTAL PAYABLE BILL</span>
                        <span class="text-base font-black text-red-500">৳<%= Number(order.totalAmount).toLocaleString() %></span>
                    </div>
                </div>

                <div class="p-6 md:p-8">
                    
                    <% 
                        // Current order status format configuration
                        const activeStatus = order.status ? order.status.toLowerCase() : 'pending'; 
                        
                        // ✅ বাংলাদেশ টাইমজোন (Asia/Dhaka) ফিক্সড ফাংশন
                        const formatTime = (dateObj) => {
                            if(!dateObj) return '';
                            return new Date(dateObj).toLocaleString('en-US', { 
                                timeZone: 'Asia/Dhaka',
                                hour: 'numeric', 
                                minute: 'numeric', 
                                hour12: true,
                                day: 'numeric', 
                                month: 'short', 
                                year: 'numeric' 
                            });
                        };
                    %>

                    <div class="relative pl-8 space-y-12 before:absolute before:inset-y-2 before:left-3 before:w-[2px] before:bg-gray-100">
                        
                        <!-- Step 1: Order Placed -->
                        <div class="relative group">
                            <span class="absolute -left-8 top-0.5 w-6 h-6 rounded-full bg-green-500 border-4 border-white text-white flex items-center justify-center text-[9px] shadow-md z-10">
                                <i class="fa-solid fa-check"></i>
                            </span>
                            <div class="space-y-0.5">
                                <h4 class="text-sm font-black text-gray-900 uppercase tracking-tight">Order Placed</h4>
                                <p class="text-xs text-gray-400 leading-relaxed">আপনার অর্ডারটি সিস্টেমে পেন্ডিং অবস্থায় সফলভাবে যুক্ত হয়েছে।</p>
                                <span class="inline-block text-[10px] text-gray-500 font-bold bg-gray-50 px-2 py-0.5 rounded border border-gray-100 font-mono mt-1">
                                    <i class="fa-regular fa-clock mr-1"></i> <%= formatTime(order.createdAt) %>
                                </span>
                            </div>
                        </div>

                        <!-- Step 2: Order Confirmed -->
                        <% const isConfirmed = ['confirmed', 'shipped', 'delivered'].includes(activeStatus); %>
                        <div class="relative group">
                            <span class="absolute -left-8 top-0.5 w-6 h-6 rounded-full border-4 border-white flex items-center justify-center text-[9px] shadow-md z-10 <%= isConfirmed ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-400' %>">
                                <i class="fa-solid <%= isConfirmed ? 'fa-check' : 'fa-circle-notch animate-spin' %>"></i>
                            </span>
                            <div class="space-y-0.5">
                                <h4 class="text-sm font-black uppercase tracking-tight <%= isConfirmed ? 'text-gray-900' : 'text-gray-400 font-medium' %>">Order Confirmed</h4>
                                <p class="text-xs text-gray-400 leading-relaxed">অ্যাডমিন আপনার অর্ডারটি যাচাই করে কনফার্ম করেছেন।</p>
                                <% if(order.statusTimestamps && order.statusTimestamps.confirmedAt) { %>
                                    <span class="inline-block text-[10px] text-gray-500 font-bold bg-gray-50 px-2 py-0.5 rounded border border-gray-100 font-mono mt-1">
                                        <i class="fa-regular fa-clock mr-1"></i> <%= formatTime(order.statusTimestamps.confirmedAt) %>
                                    </span>
                                <% } %>
                            </div>
                        </div>

                        <!-- Step 3: Shipped -->
                        <% const isShipped = ['shipped', 'delivered'].includes(activeStatus); %>
                        <div class="relative group">
                            <span class="absolute -left-8 top-0.5 w-6 h-6 rounded-full border-4 border-white flex items-center justify-center text-[9px] shadow-md z-10 <%= isShipped ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-400' %>">
                                <i class="fa-solid <%= isShipped ? 'fa-check' : 'fa-truck-fast' %>"></i>
                            </span>
                            <div class="space-y-0.5">
                                <h4 class="text-sm font-black uppercase tracking-tight <%= isShipped ? 'text-gray-900' : 'text-gray-400 font-medium' %>">Dispatched / Shipped</h4>
                                <p class="text-xs text-gray-400 leading-relaxed">প্যাকেজটি কুরিয়ার সার্ভিস এজেন্টের কাছে হস্তান্তর করা হয়েছে।</p>
                                <% if(order.statusTimestamps && order.statusTimestamps.shippedAt) { %>
                                    <span class="inline-block text-[10px] text-gray-500 font-bold bg-gray-50 px-2 py-0.5 rounded border border-gray-100 font-mono mt-1">
                                        <i class="fa-regular fa-clock mr-1"></i> <%= formatTime(order.statusTimestamps.shippedAt) %>
                                    </span>
                                <% } %>
                            </div>
                        </div>

                        <!-- Step 4: Delivered -->
                        <% const isDelivered = activeStatus === 'delivered'; %>
                        <div class="relative group">
                            <span class="absolute -left-8 top-0.5 w-6 h-6 rounded-full border-4 border-white flex items-center justify-center text-[9px] shadow-md z-10 <%= isDelivered ? 'bg-green-500 text-white' : 'bg-gray-200 text-gray-400' %>">
                                <i class="fa-solid fa-house-chimney-user"></i>
                            </span>
                            <div class="space-y-0.5">
                                <h4 class="text-sm font-black uppercase tracking-tight <%= isDelivered ? 'text-gray-900' : 'text-gray-400 font-medium' %>">Successfully Delivered</h4>
                                <p class="text-xs text-gray-400 leading-relaxed">অর্ডারটি আপনার ঠিকানায় সফলভাবে পৌঁছে দেওয়া হয়েছে।</p>
                                <% if(order.statusTimestamps && order.statusTimestamps.deliveredAt) { %>
                                    <span class="inline-block text-[10px] text-gray-500 font-bold bg-gray-50 px-2 py-0.5 rounded border border-gray-100 font-mono mt-1">
                                        <i class="fa-regular fa-clock mr-1"></i> <%= formatTime(order.statusTimestamps.deliveredAt) %>
                                    </span>
                                <% } %>
                            </div>
                        </div>

                    </div>
                    
                </div>
            </div>
        <% } %>

    </div>
</section>

<%- include('partials/footer') %>