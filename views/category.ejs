<%- include('partials/headr') %>

<div class="w-full min-h-screen bg-white">
    <section class="py-10">
        <div class="container mx-auto px-6">
            
            <!-- Simple Clean Breadcrumb Header Title -->
            <h2 class="text-2xl font-bold text-gray-900 mb-8 pb-4 border-b">
                Category &gt; <span class="text-red-600 capitalize"><%= currentCategory %></span>
            </h2>
            
            <!-- Standard Minimal Product Grid Components Layout -->
            <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                <!-- Products dynamically rendered via JavaScript loop inside nodes -->
            </div>
        </div>
    </section>

    <script>
        const products = <%- JSON.stringify(posts) %>;
        const productGrid = document.getElementById('product-grid');

        // Safe pipeline processing interface loops
        products.forEach(product => {
            const isDiscountActive = product.isDiscount === true || product.isDiscount === 'true';
            const regularPrice = parseFloat(product.regularPrice) || parseFloat(product.price) || 0;
            const discountPrice = parseFloat(product.discountPrice) || 0;
            
            let activePrice = regularPrice;
            let saleBadgeMarkup = '';

            if (isDiscountActive && discountPrice > 0 && discountPrice < regularPrice) {
                activePrice = discountPrice;
                saleBadgeMarkup = `
                    <span class="absolute top-2 left-2 bg-red-600 text-white font-bold text-[10px] tracking-wider px-2 py-0.5 uppercase rounded-sm">
                        SALE
                    </span>
                `;
            }

            // Safe String filter escape processor injection configurations
            const sanitizedTitle = product.title.replace(/'/g, "\\'");

            productGrid.innerHTML += `
                <div class="border border-gray-200 rounded-sm p-4 bg-white flex flex-col justify-between hover:shadow-sm transition-shadow">
                    
                    <!-- Product Image Wrapper Element -->
                    <div class="relative overflow-hidden bg-gray-50 rounded-sm aspect-square mb-4">
                        ${saleBadgeMarkup}
                        <a href="/product/${product._id}" class="cursor-pointer hover:opacity-80">
                            
                        <img src="${product.imgUrl}" alt="${product.title}" class="w-full h-full object-cover">
                         </a> 
                        <!-- Fixed Static Classic View Details Button Overlay Panel Link -->
                       
                    </div>

                    <!-- Description Meta Data Container -->
                    <div class="flex-1 flex flex-col justify-between">
                        <div>
                            <span class="text-[10px] font-semibold text-gray-400 uppercase tracking-wider block mb-1">
                                ${product.category}
                            </span>
                            <h3 class="text-sm font-medium text-gray-900 line-clamp-2 min-h-[40px] leading-snug">
                                ${product.title}
                            </h3>
                        </div>

                        <!-- Price Point Layout Segments -->
                        <div class="mt-2 flex items-baseline gap-2">
                            <span class="text-base font-bold text-red-600">
                                ৳${Number(activePrice).toLocaleString()}
                            </span>
                            ${isDiscountActive && discountPrice > 0 ? `
                                <span class="text-xs text-gray-400 line-through">
                                    ৳${Number(regularPrice).toLocaleString()}
                                </span>
                            ` : ''}
                        </div>

                        <!-- Minimal Classic Core Click Action Button Component -->
                        <button onclick="addToCart('${product._id}', '${sanitizedTitle}', '${activePrice}', '${product.imgUrl}')" 
                                class="mt-4 w-full bg-red-600 hover:bg-red-700 text-white text-xs font-bold uppercase py-3 rounded-sm transition tracking-wider cursor-pointer">
                            ADD TO CART
                        </button>
                    </div>
                </div>
            `;
        });

        // Sync global cart calculations indicators
        function updateCartCount() {
            const cart = JSON.parse(localStorage.getItem('cart')) || [];
            const countElement = document.getElementById('cart-count');
            if (countElement) {
                countElement.innerText = cart.length;
            }
        }

        window.onload = updateCartCount;

        // Secure baseline internal storage execution functions
        function addToCart(id, title, regularPrice, img) {
            let cart = JSON.parse(localStorage.getItem('cart')) || [];
            const existingItem = cart.find(item => item.id === id);

            if (existingItem) {
                existingItem.quantity += 1;
               
            Swal.fire({
                title: 'Quantity Updated!',
                text: `product has already in cart so updated quantity`,
                icon: 'info',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2500,
                timerProgressBar: true
            });
            } else {
                cart.push({ id, title, regularPrice: parseFloat(regularPrice), img, quantity: 1 });
                Swal.fire({
                title: 'Success!',
                text: `product has been added to your shopping cart.`,
                icon: 'success',
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 2500,
                timerProgressBar: true
            });
            }

            localStorage.setItem('cart', JSON.stringify(cart));
            
            // Standard synchronization pipeline dispatches
            window.dispatchEvent(new CustomEvent('cartUpdated'));
            updateCartCount();
            
        
        }
    </script>
</div>

<%- include('partials/footer') %>