<%- include('partials/headr') %>
<div class="w-full min-h-screen h-auto">
  <section class="py-10">
        <div class="container mx-auto px-6">
            <h2 class="text-3xl font-bold text-gray-900 mb-12">Category > <%= currentCategory %></h2>
            <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
                <!-- Products via JS -->
            </div>
        </div>
    </section>

    <!-- Footer -->
   

    <script>
    const products = <%- JSON.stringify(posts) %>;
    const productGrid = document.getElementById('product-grid');

    // ডাটা রেন্ডার করা
    products.forEach(product => {
        productGrid.innerHTML += `
         <div class="group">
    <div class="relative overflow-hidden bg-gray-100 rounded-sm">
        <!-- প্রোডাক্ট ইমেজ -->
        <img src="${product.imgUrl}" alt="${product.title}" class="w-full h-[400px] object-cover transition duration-700 group-hover:scale-105">
        
        <!-- হোভার কন্ট্রোলস -->
        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition duration-300 flex flex-col justify-end">
            
            <!-- Quick View / Eye Icon Button -->
            <div class="absolute top-4 right-4 translate-x-10 group-hover:translate-x-0 transition-transform duration-500">
                <a href="/product/${product._id}" class="bg-white text-black p-3 rounded-full hover:bg-red-600 hover:text-white shadow-lg flex items-center justify-center transition">
                    <i class="fa-regular fa-eye text-lg"></i>
                </a>
            </div>

            <!-- Add to Cart Button -->
            <button onclick="addToCart('${product._id}', '${product.title}', '${product.price}', '${product.imgUrl}')" 
                    class="bg-red-600 hover:bg-red-700 text-white w-full py-4 text-xs font-bold uppercase tracking-tighter transition">
                ADD TO CART
            </button>
        </div>
    </div>

    <!-- Category Badge -->
    <div class="mt-3 text-[10px] uppercase tracking-widest px-2 py-1 border border-orange-500 text-orange-600 font-bold w-fit rounded">
        ${product.category}
    </div>

    <!-- Product Info (Title & Price increased) -->
    <div class="mt-4">
        <h3 class="text-lg font-bold text-gray-900 leading-tight">
            ${product.title}
        </h3>
        <p class="text-xl font-black text-red-600 mt-1">
            ৳${product.price}
        </p>
    </div>
</div>
        `;
    });


    function updateCartCount() {
        const cart = JSON.parse(localStorage.getItem('cart')) || [];
        const countElement = document.getElementById('cart-count');
        if (countElement) {
            countElement.innerText = cart.length;
        }
    }

    // পেজ রিফ্রেশ দিলেও যেন সংখ্যাটা ঠিক থাকে
    window.onload = updateCartCount;

    // LocalStorage-এ ডাটা সেভ করার ফাংশন
    function addToCart(id, title, price, img) {
        // ১. আগে থেকে কার্টে কিছু আছে কি না দেখা (না থাকলে খালি অ্যারে)
        let cart = JSON.parse(localStorage.getItem('cart')) || [];

        // ২. আইটেমটি অলরেডি কার্টে আছে কি না চেক করা
        const existingItem = cart.find(item => item.id === id);

        if (existingItem) {
            existingItem.quantity += 1; // থাকলে পরিমাণ বাড়ানো
        } else {
            // না থাকলে নতুন অবজেক্ট পুশ করা
            cart.push({
                id: id,
                title: title,
                price: price,
                img: img,
                quantity: 1
            });
        }

        // ৩. LocalStorage-এ আবার সেভ করা
        localStorage.setItem('cart', JSON.stringify(cart));
const event = new CustomEvent('cartUpdated');
        window.dispatchEvent(event);
        
    }
</script>
</div>
<%- include('partials/footer') %>