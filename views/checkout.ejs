<%- include('partials/headr') %>

<div class="container mx-auto px-6 py-12">
    <div class="max-w-4xl mx-auto bg-white p-8 rounded-2xl shadow-lg border border-gray-100">
        <h2 class="text-3xl font-bold mb-8 text-gray-800 border-b pb-4">Checkout Details</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <form id="order-form" class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700">Full Name</label>
                    <input type="text" id="name" required class="w-full mt-1 px-4 py-3 border rounded-lg outline-none focus:ring-2 focus:ring-black">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700">Phone Number</label>
                    <input type="tel" id="phone" required class="w-full mt-1 px-4 py-3 border rounded-lg outline-none focus:ring-2 focus:ring-black">
                </div>
                <div>
                    <label class="block text-sm font-semibold text-gray-700">Full Address</label>
                    <textarea id="address" required rows="3" class="w-full mt-1 px-4 py-3 border rounded-lg outline-none focus:ring-2 focus:ring-black"></textarea>
                </div>
                <button type="submit" class="w-full bg-black text-white py-4 rounded-lg font-bold uppercase tracking-widest hover:bg-gray-800 transition shadow-lg cursor-pointer">
                    Place Order
                </button>
            </form>

            <div class="bg-gray-50 p-6 rounded-xl border flex flex-col justify-between">
                <div>
                    <h4 class="text-lg font-bold mb-4">Order Summary</h4>
                    <!-- মেমোরি এবং স্ক্রল অপ্টিমাইজেশনের জন্য max-h কিছুটা বাড়ানো হয়েছে সাইজ ড্রপডাউনের সুবিধার্থে -->
                    <div id="checkout-items" class="space-y-4 mb-4 max-h-[280px] overflow-y-auto pr-1">
                    </div>
                </div>
                
                <div class="border-t pt-4 space-y-2">
                    <div class="flex justify-between text-sm text-gray-600">
                        <span>Subtotal:</span>
                        <span id="summary-subtotal">৳0.00</span>
                    </div>
                    <div class="flex justify-between text-sm text-gray-600">
                        <span>Shipping Fee:</span>
                        <span id="summary-shipping">৳0.00</span>
                    </div>
                    <div class="border-t pt-2 text-xl font-black text-red-600 flex justify-between">
                        <span>Total Bill:</span>
                        <span id="checkout-total">৳0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    let globalFinalTotal = 0;

    function loadCheckout() {
        const cart = JSON.parse(localStorage.getItem('cart')) || [];
        const container = document.getElementById('checkout-items');
        const subtotalEl = document.getElementById('summary-subtotal');
        const shippingEl = document.getElementById('summary-shipping');
        const totalEl = document.getElementById('checkout-total');
        
        if (cart.length === 0) {
            window.location.href = '/cart';
            return;
        }

        let subtotal = 0;
        
        container.innerHTML = cart.map((item, index) => {
            const rawPrice = item.regularPrice ? item.regularPrice.toString() : "0";
            const itemPrice = parseFloat(rawPrice.replace(/[^0-9.-]+/g, "")) || 0;
            const itemTotal = itemPrice * item.quantity;
            subtotal += itemTotal;

            // 🏷️ প্রোডাক্টের জন্য নির্দিষ্ট সাইজ অপশনগুলো তৈরি করা হচ্ছে
            let sizeSelectHtml = '';
            if (item.sizes && item.sizes.length > 0) {
                sizeSelectHtml = `
                    <div class="mt-1">
                        <select onchange="updateCartItemSize(${index}, this.value)" class="size-dropdown border text-xs rounded px-2 py-1 bg-white outline-none focus:border-black font-medium text-gray-700">
                            <option value="">-- Choose Size * --</option>
                            ${item.sizes.map(size => `
                                <option value="${size}" ${item.selectedSize === size ? 'selected' : ''}>Size: ${size}</option>
                            `).join('')}
                        </select>
                    </div>
                `;
            } else {
                sizeSelectHtml = `<span class="text-xs text-gray-400 block mt-1">Free Size</span>`;
            }

            return `
                <div class="border-b pb-3 text-sm text-gray-600">
                    <div class="flex justify-between items-start gap-2">
                        <div class="flex-1">
                            <span class="line-clamp-1 font-medium text-gray-800">${item.title}</span>
                            <strong class="text-black font-semibold text-xs">Qty: ${item.quantity}</strong>
                            ${sizeSelectHtml}
                        </div>
                        <span class="whitespace-nowrap font-semibold text-gray-900 mt-0.5">৳${itemTotal.toFixed(2)}</span>
                    </div>
                </div>
            `;
        }).join('');
        
        let shippingFee = subtotal >= 3500 ? 0 : 80;
        globalFinalTotal = subtotal + shippingFee;

        subtotalEl.innerText = '৳' + subtotal.toFixed(2);
        shippingEl.innerText = shippingFee === 0 ? 'Free' : '৳' + shippingFee.toFixed(2);
        totalEl.innerText = '৳' + globalFinalTotal.toFixed(2);
    }

    // 💾 ড্রপডাউন চেঞ্জ হলে যেন লোকাল স্টোরেজেও সিলেক্টেড সাইজ সেভ হয়ে যায়
    function updateCartItemSize(index, newSize) {
        let cart = JSON.parse(localStorage.getItem('cart')) || [];
        if (cart[index]) {
            cart[index].selectedSize = newSize;
            localStorage.setItem('cart', JSON.stringify(cart));
        }
    }

    document.getElementById('order-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const cart = JSON.parse(localStorage.getItem('cart')) || [];
        if (cart.length === 0) {
            Swal.fire('Error', 'Your cart is empty!', 'error');
            return;
        }
        
        // 🚨 🔍 সাইজ ভ্যালিডেশন চেকার লুপ
        for (let i = 0; i < cart.length; i++) {
            // যদি প্রোডাক্টের সাইজ অপশন থাকে কিন্তু ইউজার সাইজ সিলেক্ট না করে থাকে
            if (cart[i].sizes && cart[i].sizes.length > 0 && !cart[i].selectedSize) {
                Swal.fire({
                    title: 'Size Required!',
                    text: `দয়া করে "${cart[i].title}" প্রোডাক্টটির সাইজ সিলেক্ট করুন!`,
                    icon: 'warning',
                    confirmButtonColor: '#000000'
                });
                return; // এখানেই কোড এক্সিকিউশন স্টপ করে দেবে, রিকোয়েস্ট সার্ভারে যাবে না
            }
        }
        
        const orderData = {
            name: document.getElementById('name').value,
            phone: document.getElementById('phone').value,
            address: document.getElementById('address').value,
            items: cart, // আপডেটেড selectedSize সহ পুরো কার্ট অবজেক্ট ব্যাকএন্ডে সাবমিট হবে
            totalAmount: globalFinalTotal
        };

        try {
            Swal.fire({
                title: 'Processing Order...',
                text: 'Please wait while we secure your booking.',
                allowOutsideClick: false,
                didOpen: () => { Swal.showLoading(); }
            });

            const response = await fetch('/place-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderData)
            });

            const result = await response.json();

            if (result.success) {
                Swal.fire({
                    icon: 'success',
                    title: 'Order Placed Successfully!',
                    text: 'আপনার অর্ডারটি সফল হয়েছে। আইডিটি পরবর্তী ট্র্যাকিং এর জন্য সেভ রাখুন।',
                    confirmButtonText: 'View Order ID',
                    confirmButtonColor: '#000000'
                }).then(() => {
                    localStorage.removeItem('cart');
                    window.dispatchEvent(new CustomEvent('cartUpdated'));
                    window.location.href = `/order-success/${result.customOrderId}`;
                });
            } else {
                Swal.fire('Failed', result.message || 'অর্ডারটি সম্পন্ন করা যায়নি।', 'error');
            }
        } catch (error) {
            Swal.fire('Error', 'সার্ভারে কানেক্ট করতে সমস্যা হচ্ছে, আবার চেষ্টা করুন!', 'error');
        }
    });

    document.addEventListener('DOMContentLoaded', loadCheckout);
</script>

<%- include('partials/footer') %>