<%- include('partials/headr') %>

<div class="w-full min-h-screen bg-gray-50 flex items-center justify-center p-4 sm:p-6">
    <div class="bg-white p-6 sm:p-8 rounded-2xl shadow-xl w-full max-w-2xl border border-gray-100">
        
        <!-- Page Title -->
        <h2 class="text-2xl sm:text-3xl font-black mb-6 sm:mb-8 text-gray-900 text-center uppercase tracking-tighter italic">
            Edit <span class="text-red-600">Product</span>
        </h2>
        
        <!-- Dynamic Target Action Module -->
        <form action="/edit/<%= product._id %>" method="POST" class="space-y-5 sm:space-y-6">
            
            <!-- Title Input Field -->
            <div>
                <label class="block text-xs font-black text-gray-700 uppercase tracking-widest mb-2">Product Title</label>
                <input type="text" name="title" value="<%= product.title %>" required placeholder="Ex: Premium Cotton Polo Shirt" 
                    class="block w-full px-4 py-3 bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-red-600 outline-none transition-all font-medium text-sm">
            </div>

            <!-- Category Section (Radio Grid) -->
            <div>
                <label class="block text-xs font-black text-gray-700 uppercase tracking-widest mb-3">Select Category</label>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-2.5">
                    <% categories.forEach((cat) => { %>
                    <label class="relative flex items-center p-3 border-2 border-gray-100 rounded-xl cursor-pointer hover:border-red-500 hover:bg-red-50 transition-all group">
                        <input type="radio" name="category" value="<%= cat %>" class="peer hidden" <%= product.category === cat ? 'checked' : '' %>>
                        <span class="text-[10px] font-bold text-gray-600 uppercase group-hover:text-red-600 transition-colors"><%= cat %>'s</span>
                        <div class="absolute inset-0 border-2 border-transparent peer-checked:border-red-600 rounded-xl pointer-events-none"></div>
                    </label>
                    <% }); %>
                </div>
            </div>

            <!-- Pricing & Status Switches Container -->
            <div class="p-4 sm:p-5 bg-gray-50 rounded-2xl border border-gray-100 space-y-5 sm:space-y-6">
                <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
                    
                    <!-- Toggle Switch Grid -->
                    <div class="space-y-3">
                        <!-- Discount Toggle -->
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="isDiscount" id="discountToggle" value="true" class="sr-only peer" <%= product.isDiscount ? 'checked' : '' %>>
                            <div class="w-10 h-5 bg-gray-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-red-600"></div>
                            <span class="ms-3 text-[11px] font-black text-gray-700 uppercase select-none">On Discount?</span>
                        </label>

                        <!-- New Arrival Toggle -->
                        <label class="relative inline-flex items-center cursor-pointer block">
                            <input type="checkbox" name="isNewArrival" value="true" class="sr-only peer" <%= product.isNewArrival ? 'checked' : '' %>>
                            <div class="w-10 h-5 bg-gray-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                            <span class="ms-3 text-[11px] font-black text-gray-700 uppercase select-none">New Arrival?</span>
                        </label>
                        
                        <!-- Limited Stock Toggle -->
                        <label class="relative inline-flex items-center cursor-pointer block">
                            <input type="checkbox" name="isLimited" value="true" class="sr-only peer" <%= product.isLimited ? 'checked' : '' %>>
                            <div class="w-10 h-5 bg-gray-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-amber-500"></div>
                            <span class="ms-3 text-[11px] font-black text-gray-700 uppercase select-none">Is Limited?</span>
                        </label>
                    </div>

                    <!-- Regular Price Field -->
                    <div class="w-full md:w-1/2">
                        <label class="block text-xs font-black text-gray-700 uppercase mb-2">Regular Price (৳)</label>
                        <input type="number" name="regularPrice" value="<%= product.regularPrice %>" required placeholder="0.00" 
                            class="block w-full px-4 py-2 bg-white border border-gray-200 rounded-lg focus:border-red-600 outline-none text-sm font-medium">
                    </div>
                </div>

                <!-- Conditional Discount Price Field Box -->
                <div id="discountFieldContainer" class="<%= product.isDiscount ? '' : 'hidden' %> pt-4 border-t border-gray-200 animate-fadeIn">
                    <label class="block text-[10px] font-black text-red-700 uppercase mb-1">Discount Price (৳)</label>
                    <input type="number" name="discountPrice" id="discountPriceInput" value="<%= product.discountPrice %>" placeholder="Enter discounted price" 
                        class="w-full px-4 py-2 text-sm border border-red-200 rounded-lg outline-none focus:border-red-600 bg-red-50 font-medium" <%= product.isDiscount ? 'required' : '' %>>
                </div>
            </div>

            <!-- Image Asset Link Elements Grid -->
            <div class="space-y-3.5">
                <label class="block text-xs font-black text-gray-700 uppercase tracking-widest italic">Image Gallery</label>
                <input type="url" name="imgUrl" value="<%= product.imgUrl %>" required placeholder="Main Image URL (Required)" 
                    class="block w-full px-4 py-3 bg-white border-2 border-gray-100 rounded-xl focus:border-red-600 outline-none transition-all shadow-sm text-sm">
                
                <div class="grid grid-cols-2 gap-3">
                    <input type="url" name="imgUrl2" value="<%= product.imgUrl2 || '' %>" placeholder="Gallery 1 (Opt)" class="px-4 py-2 text-xs sm:text-sm bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-gray-900">
                    <input type="url" name="imgUrl3" value="<%= product.imgUrl3 || '' %>" placeholder="Gallery 2 (Opt)" class="px-4 py-2 text-xs sm:text-sm bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-gray-900">
                    <input type="url" name="imgUrl4" value="<%= product.imgUrl4 || '' %>" placeholder="Gallery 3 (Opt)" class="px-4 py-2 text-xs sm:text-sm bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-gray-900">
                    <input type="url" name="imgUrl5" value="<%= product.imgUrl5 || '' %>" placeholder="Gallery 4 (Opt)" class="px-4 py-2 text-xs sm:text-sm bg-gray-50 border border-gray-200 rounded-lg outline-none focus:border-gray-900">
                </div>
            </div>

            <!-- Content Description Markups -->
            <div>
                <label class="block text-xs font-black text-gray-700 uppercase tracking-widest mb-2">Description</label>
                <textarea name="content" rows="3" placeholder="Describe fabric structure, quality specs etc..." 
                    class="block w-full px-4 py-3 bg-gray-50 border-2 border-gray-100 rounded-xl focus:border-red-600 outline-none transition-all text-sm font-medium"><%= product.content %></textarea>
            </div>

            <!-- Form Submit Execution Button Trigger -->
            <button type="submit" 
                class="w-full bg-gray-900 hover:bg-red-600 text-white font-black py-4 rounded-xl shadow-lg transition duration-200 uppercase tracking-[0.15em] text-xs cursor-pointer">
                Save Changes
            </button>
            
        </form>
    </div>
</div>

<script>
    // Frontend dynamic toggle tracking script matching auto loop logic
    const discountToggle = document.getElementById('discountToggle');
    const discountFieldContainer = document.getElementById('discountFieldContainer');
    const discountPriceInput = document.getElementById('discountPriceInput');

    discountToggle.addEventListener('change', function() {
        if (this.checked) {
            discountFieldContainer.classList.remove('hidden');
            discountPriceInput.required = true;
        } else {
            discountFieldContainer.classList.add('hidden');
            discountPriceInput.value = "";
            discountPriceInput.required = false;
        }
    });
</script>

<style>
    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-8px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .animate-fadeIn {
        animation: fadeIn 0.25s ease-out forwards;
    }
</style>

<%- include('partials/footer') %>